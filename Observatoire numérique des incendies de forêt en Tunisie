<script>
  // Menu burger (mobile)
  const burger = document.getElementById('burger');
  const navMenu = document.getElementById('navMenu');
  burger.addEventListener('click', () => navMenu.classList.toggle('open'));
  navMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => navMenu.classList.remove('open')));

  // S'assurer que l'iFrame Power BI occupe toujours la pleine largeur de la page web
  function fitPowerBIToViewport() {
    const frame = document.getElementById('powerbi-frame');
    if (!frame) return;
    // Largeur = largeur du conteneur parent (pleine largeur de la page)
    const wrap = frame.parentElement;
    const w = wrap.clientWidth - 16; // padding interne
    frame.style.width = '100%';
    frame.style.maxWidth = 'none';
    frame.style.minWidth = '0';
    // Hauteur adaptative pour un bon ratio de lecture
    const h = Math.max(540, Math.min(900, Math.round(window.innerHeight * 0.78)));
    frame.style.height = h + 'px';
  }
  window.addEventListener('load', fitPowerBIToViewport);
  window.addEventListener('resize', fitPowerBIToViewport);
</script>

