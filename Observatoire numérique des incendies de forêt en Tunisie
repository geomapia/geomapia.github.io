<!-- ============================================================
     SECTION 2 — À PROPOS
     ============================================================ -->
<section class="about section-pad" id="apropos">
  <div class="container">
    <div class="section-subtitle">Contexte du projet</div>
    <h2 class="section-title">À propos du projet</h2>
    <div class="section-divider"></div>

    <div class="about-grid">
      <!-- Carte 1 : Zone d'étude -->
      <div class="about-card">
        <div class="about-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/>
            <line x1="8" y1="2" x2="8" y2="18"/>
            <line x1="16" y1="6" x2="16" y2="22"/>
          </svg>
        </div>
        <h3>Zone d'étude</h3>
        <p><strong>7 gouvernorats</strong> du Tell Septentrional Tunisien couverts par l'analyse spatiale des incendies de forêt.</p>
      </div>

      <!-- Carte 2 : Base de données -->
      <div class="about-card">
        <div class="about-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <ellipse cx="12" cy="5" rx="9" ry="3"/>
            <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
            <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
          </svg>
        </div>
