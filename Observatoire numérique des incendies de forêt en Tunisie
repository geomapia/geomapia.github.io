<!-- ============================================================
     SECTION 1 — HEADER / ACCUEIL
     ============================================================ -->
<header class="hero" id="accueil">
  <div class="hero-content">
    <span class="hero-tag">SIG &amp; Business Intelligence</span>
    <h1>Plateforme <span class="accent">Incendie</span></h1>
    <p class="subtitle">Tell Septentrional Tunisien — 2002/2023</p>
    <p class="desc">Système d'Information Géographique &amp; Business Intelligence</p>
