<!-- ============================================================
     SECTION 3 — TABLEAU DE BORD
     ============================================================ -->
<section class="dashboard section-pad" id="tableau-de-bord">
  <div class="container">
    <div class="section-subtitle">Power BI Embedded</div>
    <h2 class="section-title">Tableau de bord interactif</h2>
    <div class="section-divider"></div>

    <p class="dashboard-intro">
      Visualisation dynamique des données d'incendies de forêt du Tell Septentrional Tunisien.
      Filtrez par gouvernorat, par année et par type d'occupation du sol pour explorer l'évolution
      spatio-temporelle des feux et des surfaces brûlées entre 2002 et 2023.
    </p>

    <div class="dashboard-frame-wrap">
      <div class="dashboard-meta">
        <span><span class="dot"></span>Dashboard Power BI — Connexion en direct</span>
        <span>Maj : 2023 &middot; Source : DGF / FIRMS / Copernicus</span>
      </div>

      <!-- ========================================================
           IFRAME POWER BI
