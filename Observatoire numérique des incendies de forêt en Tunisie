<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Observatoire numérique des incendies de forêt en Tunisie</title>
<meta name="description" content="Plateforme Incendie — Tell Septentrional Tunisien 2002/2023. Système d'Information Géographique & Business Intelligence." />
<style>
  /* =========================================================
     PALETTE GLOBALE
     ========================================================= */
  :root {
    --bg-principal:   #1a2e1a;
    --bg-secondaire:  #0d1a0d;
    --bg-troisieme:   #15281a;
    --accent-orange:  #FF4500;
    --accent-orange-2:#ff6a33;
    --text-clair:     #9FE1CB;
    --text-blanc:     #FFFFFF;
    --border-soft:    rgba(159, 225, 203, 0.15);
    --card-bg:        rgba(255, 255, 255, 0.03);
    --shadow-orange:  0 8px 30px rgba(255, 69, 0, 0.25);
  }

  /* =========================================================
     RESET & BASE
     ========================================================= */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Segoe UI', 'Helvetica Neue', Arial, system-ui, sans-serif;
    background-color: var(--bg-principal);
    color: var(--text-clair);
    line-height: 1.6;
    overflow-x: hidden;
  }
  section { width: 100%; }
  a { color: inherit; text-decoration: none; }
  img, svg { display: block; max-width: 100%; }

  /* =========================================================
     NAVIGATION
     ========================================================= */
  nav.topbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(13, 26, 13, 0.85);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border-soft);
  }
  nav.topbar .nav-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.9rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  nav.topbar .brand {
    color: var(--text-blanc);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  nav.topbar .brand .flame { color: var(--accent-orange); }
  nav.topbar ul {
    list-style: none;
    display: flex;
    gap: 1.8rem;
    align-items: center;
  }
  nav.topbar ul li a {
    color: var(--text-clair);
    font-size: 0.95rem;
    font-weight: 500;
    padding: 0.4rem 0;
    position: relative;
    transition: color 0.25s ease;
  }
  nav.topbar ul li a::after {
    content: '';
    position: absolute;
    left: 0; bottom: -2px;
    height: 2px; width: 0;
    background: var(--accent-orange);
    transition: width 0.3s ease;
  }
  nav.topbar ul li a:hover { color: var(--text-blanc); }
  nav.topbar ul li a:hover::after { width: 100%; }
  .burger { display: none; font-size: 1.6rem; color: var(--text-blanc); cursor: pointer; background: none; border: none; }

  /* =========================================================
     LAYOUTS GÉNÉRIQUES
     ========================================================= */
  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .section-pad { padding: 6rem 0; }
  .section-title {
    color: var(--text-blanc);
    font-size: clamp(1.8rem, 3.2vw, 2.6rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 0.75rem;
    letter-spacing: -0.5px;
  }
  .section-subtitle {
    color: var(--accent-orange);
    text-align: center;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    margin-bottom: 3rem;
    font-weight: 600;
  }
  .section-divider {
    width: 80px; height: 4px;
    background: var(--accent-orange);
    margin: 0 auto 3rem;
    border-radius: 2px;
  }

  /* =========================================================
     SECTION 1 — HEADER / ACCUEIL
     ========================================================= */
  header.hero {
    min-height: 100vh;
    background:
      radial-gradient(ellipse at top right, rgba(255, 69, 0, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at bottom left, rgba(159, 225, 203, 0.06) 0%, transparent 55%),
      linear-gradient(135deg, #0d1a0d 0%, #1a2e1a 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 7rem 1.5rem 4rem;
    position: relative;
    overflow: hidden;
  }
  header.hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(0deg, rgba(159,225,203,0.025) 0 1px, transparent 1px 60px),
      repeating-linear-gradient(90deg, rgba(159,225,203,0.025) 0 1px, transparent 1px 60px);
    pointer-events: none;
  }
  .hero-content { max-width: 900px; position: relative; z-index: 2; }
  .hero-tag {
    display: inline-block;
    color: var(--accent-orange);
    border: 1px solid var(--accent-orange);
    padding: 0.35rem 1rem;
    border-radius: 50px;
    font-size: 0.8rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    font-weight: 600;
  }
  .hero-content h1 {
    color: var(--text-blanc);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.05;
    margin-bottom: 1rem;
    letter-spacing: -1.5px;
  }
  .hero-content h1 .accent { color: var(--accent-orange); }
  .hero-content .subtitle {
    color: var(--text-clair);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 500;
    margin-bottom: 0.5rem;
  }
  .hero-content .desc {
    color: var(--text-clair);
    opacity: 0.85;
    font-size: 1rem;
    margin-bottom: 2.5rem;
  }
  .hero-btn {
    display: inline-block;
    background: var(--accent-orange);
    color: var(--text-blanc);
    padding: 1rem 2.2rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: 0.5px;
    box-shadow: var(--shadow-orange);
    transition: all 0.3s ease;
    border: 2px solid var(--accent-orange);
  }
  .hero-btn:hover {
    background: transparent;
    color: var(--accent-orange);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(255, 69, 0, 0.4);
  }
  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    margin-top: 4rem;
    flex-wrap: wrap;
  }
  .hero-stats .stat-num {
    color: var(--accent-orange);
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
  }
  .hero-stats .stat-lbl {
    color: var(--text-clair);
    font-size: 0.85rem;
    margin-top: 0.3rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* =========================================================
     SECTION 2 — À PROPOS
     ========================================================= */
  section.about {
    background: var(--bg-troisieme);
    border-top: 1px solid var(--border-soft);
    border-bottom: 1px solid var(--border-soft);
  }
  .about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
    margin-top: 1rem;
  }
  .about-card {
    background: var(--card-bg);
    border: 1px solid var(--border-soft);
    border-radius: 16px;
    padding: 2.5rem 2rem;
    text-align: center;
    transition: all 0.35s ease;
    position: relative;
    overflow: hidden;
  }
  .about-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 3px;
    background: linear-gradient(90deg, var(--accent-orange), transparent);
    opacity: 0; transition: opacity 0.35s ease;
  }
  .about-card:hover { transform: translateY(-6px); border-color: var(--accent-orange); }
  .about-card:hover::before { opacity: 1; }
  .about-icon {
    width: 64px; height: 64px;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255, 69, 0, 0.12);
    color: var(--accent-orange);
  }
  .about-icon svg { width: 32px; height: 32px; }
  .about-card h3 {
    color: var(--text-blanc);
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }
  .about-card p {
    color: var(--text-clair);
    font-size: 0.95rem;
    opacity: 0.85;
  }
  .about-card p strong { color: var(--accent-orange); font-weight: 700; }

  /* =========================================================
     SECTION 3 — TABLEAU DE BORD
     ========================================================= */
  section.dashboard { background: var(--bg-secondaire); }
  .dashboard-intro {
    max-width: 800px;
    margin: 0 auto 2.5rem;
    text-align: center;
    color: var(--text-clair);
    font-size: 1.05rem;
    opacity: 0.9;
  }
  .dashboard-frame-wrap {
    background: var(--bg-principal);
    border: 1px solid var(--border-soft);
    border-radius: 18px;
    padding: 0.5rem;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    position: relative;
  }
  .dashboard-frame-wrap::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 18px;
    padding: 1px;
    background: linear-gradient(135deg, var(--accent-orange), transparent 40%, transparent 60%, var(--text-clair));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
    opacity: 0.4;
  }
  /* L'iFrame occupe toute la largeur de la page web */
  .dashboard-frame-wrap iframe {
    width: 100%;
    width: 100vw;
    max-width: 100% !important;
    height: 720px;
    border: 0;
    border-radius: 14px;
    background: var(--bg-secondaire);
    display: block;
  }
  .dashboard-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.9rem 1rem;
    font-size: 0.85rem;
    color: var(--text-clair);
    opacity: 0.8;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .dashboard-meta .dot {
    display: inline-block;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--accent-orange);
    margin-right: 0.4rem;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.4); }
  }

  /* =========================================================
     SECTION 4 — CARTES
     ========================================================= */
  section.maps { background: var(--bg-principal); border-top: 1px solid var(--border-soft); }
  .maps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    margin-top: 1rem;
  }
  .map-card {
    background: var(--card-bg);
    border: 1px solid var(--border-soft);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.35s ease;
    cursor: pointer;
  }
  .map-card:hover { transform: translateY(-6px); border-color: var(--accent-orange); box-shadow: var(--shadow-orange); }
  .map-preview {
    height: 240px;
    background:
      radial-gradient(circle at 30% 40%, rgba(255, 69, 0, 0.35) 0%, transparent 30%),
      radial-gradient(circle at 70% 60%, rgba(255, 69, 0, 0.25) 0%, transparent 25%),
      radial-gradient(circle at 50% 75%, rgba(255, 165, 0, 0.2) 0%, transparent 20%),
      linear-gradient(135deg, #0d1a0d 0%, #1a2e1a 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .map-preview::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(0deg, rgba(159,225,203,0.06) 0 1px, transparent 1px 40px),
      repeating-linear-gradient(90deg, rgba(159,225,203,0.06) 0 1px, transparent 1px 40px);
  }
  .map-preview.burned {
    background:
      radial-gradient(circle at 50% 50%, rgba(80, 40, 20, 0.5) 0%, transparent 50%),
      linear-gradient(135deg, #1a1208 0%, #2a1a0d 100%);
  }
  .map-preview .symbol {
    position: relative;
    z-index: 2;
    color: var(--accent-orange);
    filter: drop-shadow(0 0 20px rgba(255, 69, 0, 0.6));
  }
  .map-preview .symbol svg { width: 80px; height: 80px; }
  .map-info { padding: 1.5rem 1.8rem; }
  .map-info h3 {
    color: var(--text-blanc);
    font-size: 1.25rem;
    margin-bottom: 0.4rem;
    font-weight: 700;
  }
  .map-info p { color: var(--text-clair); font-size: 0.92rem; opacity: 0.85; margin-bottom: 1rem; }
  .map-info .map-cta {
    color: var(--accent-orange);
    font-size: 0.9rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: gap 0.25s ease;
  }
  .map-card:hover .map-cta { gap: 0.8rem; }

  /* =========================================================
     SECTION 5 — CONTACT / SOURCES
     ========================================================= */
  section.contact {
    background: var(--bg-secondaire);
    border-top: 1px solid var(--border-soft);
    padding: 5rem 0 3rem;
    text-align: center;
  }
  .contact-author {
    color: var(--text-blanc);
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .contact-mention {
    color: var(--text-clair);
    font-size: 1rem;
    margin-bottom: 2.5rem;
    opacity: 0.9;
  }
  .contact-mention .year { color: var(--accent-orange); font-weight: 600; }
  .sources-block {
    max-width: 900px;
    margin: 0 auto 3rem;
  }
  .sources-block h4 {
    color: var(--text-clair);
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.85rem;
    margin-bottom: 1rem;
    opacity: 0.7;
  }
  .sources-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
  }
  .sources-list span {
    background: var(--card-bg);
    border: 1px solid var(--border-soft);
    color: var(--text-clair);
    padding: 0.5rem 1.1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    transition: all 0.25s ease;
  }
  .sources-list span:hover { border-color: var(--accent-orange); color: var(--accent-orange); }
  footer {
    border-top: 1px solid var(--border-soft);
    padding: 1.5rem 1.5rem;
    text-align: center;
    color: var(--text-clair);
    font-size: 0.82rem;
    opacity: 0.65;
  }
  footer a { color: var(--accent-orange); }

  /* =========================================================
     RESPONSIVE
     ========================================================= */
  @media (max-width: 768px) {
    nav.topbar ul {
      position: fixed;
      top: 56px; right: 0;
      flex-direction: column;
      background: rgba(13, 26, 13, 0.97);
      width: 70%;
      height: calc(100vh - 56px);
      padding: 2rem 1.5rem;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      gap: 1.2rem;
      align-items: flex-start;
    }
    nav.topbar ul.open { transform: translateX(0); }
    .burger { display: block; }
    .hero-stats { gap: 1.5rem; }
    .dashboard-frame-wrap iframe { height: 540px; }
    .section-pad { padding: 4rem 0; }
  }
  @media (max-width: 480px) {
    .dashboard-frame-wrap iframe { height: 420px; }
    nav.topbar .brand { font-size: 0.85rem; }
  }
</style>
</head>
<body>

<!-- ============================================================
     NAVIGATION
     ============================================================ -->
<nav class="topbar">
  <div class="nav-inner">
