<!-- ============================================================
     SECTION 4 — CARTES
     ============================================================ -->
<section class="maps section-pad" id="cartes">
  <div class="container">
    <div class="section-subtitle">Cartographie thématique</div>
    <h2 class="section-title">Cartes interactives</h2>
    <div class="section-divider"></div>

    <div class="maps-grid">
      <!-- Carte 1 : Nombre d'incendies -->
      <div class="map-card">
        <div class="map-preview">
